# BharatSync AI - Environment Variables
# Copy this file to .env and fill in your values

# =====================================================================
# GROK API KEY (by xAI)
# =====================================================================
# To enable live AI-powered chatbot responses via Grok:
# 1. Sign up at: https://console.x.ai/
# 2. Go to API Keys -> Create New Key
# 3. Paste your key below
# 4. Restart the backend server
#
# Without this key, the chatbot will still work using the built-in
# rule-based reasoning engine with full complaint DB awareness.

GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================================
# BACKEND SETTINGS (Optional - defaults work for local dev)
# =====================================================================
BACKEND_HOST=localhost
BACKEND_PORT=8000

# =====================================================================
# DATABASE (Optional - SQLite is used by default)
# =====================================================================
# DATABASE_URL=sqlite:///bharatsync.db
